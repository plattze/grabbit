{
  "manifest_version": 3,
  "name": "Send to Grabbit",
  "version": "0.1.0",
  "description": "Queue links and pages in your self-hosted Grabbit download manager.",
  "permissions": ["contextMenus", "storage", "activeTab", "notifications"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send to Grabbit"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
